# main
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="ccsweep",
        description="Claude Code session RAM cleaner — extract handoff + kill proc + 7d trash.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "examples:\n"
            "  ccsweep                       # interactive sweep of sessions >= 3d stale\n"
            "  ccsweep --days 7 --dry-run    # preview only, 7d threshold\n"
            "  ccsweep --list                # show all sessions sorted by age\n"
            "  ccsweep --pin a1b2c3d4        # pin a session by UUID prefix\n"
            "  ccsweep --restore a1b2c3d4    # restore a trashed session\n"
            "  ccsweep --gc                  # GC trash files >= 7d old\n"
        ),
    )
    p.add_argument("--days", type=int, default=DEFAULT_STALE_DAYS,
                   help=f"stale threshold in days (default {DEFAULT_STALE_DAYS})")
    p.add_argument("--include-orphans", action="store_true",
                   help="also include jsonl-only sessions (no running proc; pure disk history)")
    p.add_argument("--dry-run", action="store_true",
                   help="list candidates, take no action")
    p.add_argument("--list", action="store_true",
                   help="list all sessions sorted by age, then exit")
    p.add_argument("--pin", metavar="UUID",
                   help="add UUID (or prefix) to pin list and exit")
    p.add_argument("--unpin", metavar="UUID",
                   help="remove UUID (or prefix) from pin list and exit")
    p.add_argument("--restore", metavar="SHORT_UUID",
                   help="restore a jsonl from trash back to projects/, then exit")
    p.add_argument("--empty-trash", action="store_true",
                   help="immediately empty the trash (skip 7d grace) and exit")
    p.add_argument("--gc", action="store_true",
                   help="run trash GC only (remove files >= 7d old) and exit")
    return p


def main(argv=None) -> int:
    args = build_parser().parse_args(argv)
    TRASH_DIR.mkdir(parents=True, exist_ok=True)
    if not PIN_FILE.exists():
        save_pins(set())

    if args.list:
        return cmd_list(args)
    if args.pin:
        return cmd_pin(args)
    if args.unpin:
        return cmd_unpin(args)
    if args.restore:
        return cmd_restore(args)
    if args.empty_trash:
        return cmd_empty_trash(args)
    if args.gc:
        return cmd_gc(args)
    return cmd_scan(args)


if __name__ == "__main__":
    sys.exit(main())
